<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/primary">

    <LinearLayout
        android:id="@+id/layoutCenter"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center_horizontal"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/layoutCopyright"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintVertical_bias="0.5">

        <TextView
            android:id="@+id/txtLogo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_title"
            android:textColor="@color/white"
            android:textSize="@dimen/text_large"
            android:textStyle="bold"
            android:gravity="center"
            android:paddingBottom="@dimen/margin_small" />

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginStart="29dp"
            android:layout_marginEnd="29dp"
            app:cardCornerRadius="@dimen/card_radius"
            app:cardElevation="6dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/padding_card">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center"
                    android:text="@string/login_select_role"
                    android:textSize="@dimen/text_title"
                    android:textColor="@color/primary"
                    android:textStyle="bold"
                    android:layout_marginBottom="@dimen/margin_standard" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRoleStaff"
                    style="@style/Widget.IlcAndroid.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/padding_row"
                    android:minHeight="@dimen/btn_min_height_lg"
                    android:text="@string/role_staff"
                    android:textSize="@dimen/text_button" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRoleDriver"
                    style="@style/Widget.IlcAndroid.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/role_driver"
                    android:textSize="@dimen/text_button"
                    android:minHeight="@dimen/btn_min_height_lg"
                    android:layout_marginBottom="@dimen/padding_row" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btnRoleVendor"
                    style="@style/Widget.IlcAndroid.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/role_vendor"
                    android:textSize="@dimen/text_button"
                    android:minHeight="@dimen/btn_min_height_lg" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutCopyright"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/primary"
        android:padding="@dimen/padding_row"
        android:gravity="center_horizontal"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="58dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/login_copyright"
            android:textColor="@color/white"
            android:textSize="@dimen/text_subtitle" />

        <TextView
            android:id="@+id/txtVersion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="@dimen/text_subtitle"
            android:layout_marginTop="5dp"
            android:text="v1.0.0" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
