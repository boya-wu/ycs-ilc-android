<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/txtWorkflowTitle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/primary"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/txtStepIndicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:textColor="@color/black"
            android:layout_marginBottom="16dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/rowStep1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:foreground="?attr/selectableItemBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/step_staff" android:textSize="12sp" android:textColor="@color/primary" />
                <TextView android:id="@+id/txtStep1Value" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="16sp"
                    android:text="@string/tap_to_input" android:minHeight="40dp" android:gravity="center_vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/rowStep2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:foreground="?attr/selectableItemBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:id="@+id/txtStep2Label" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/step_driver"
                    android:textSize="12sp" android:textColor="@color/primary" />
                <TextView android:id="@+id/txtStep2Value" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="16sp"
                    android:text="@string/tap_to_input" android:minHeight="40dp" android:gravity="center_vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/rowStep3"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:foreground="?attr/selectableItemBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="@string/step_tank" android:textSize="12sp" android:textColor="@color/primary" />
                <TextView android:id="@+id/txtStep3Value" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="16sp"
                    android:text="@string/tap_to_input" android:minHeight="40dp" android:gravity="center_vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/rowStep4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="8dp"
            app:cardCornerRadius="8dp"
            app:cardElevation="2dp"
            android:foreground="?attr/selectableItemBackground">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="12dp">
                <TextView android:id="@+id/txtStep4Label" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:text="@string/step_fab"
                    android:textSize="12sp" android:textColor="@color/primary" />
                <TextView android:id="@+id/txtStep4Value" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:textSize="16sp"
                    android:text="@string/tap_to_input" android:minHeight="40dp" android:gravity="center_vertical" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <androidx.cardview.widget.CardView
            android:id="@+id/layoutConfirm"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="4dp"
            android:layout_marginTop="8dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/confirm_summary"
                    android:textStyle="bold"
                    android:textColor="@color/primary" />

                <TextView
                    android:id="@+id/txtSummary"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:textSize="14sp" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginTop="12dp">

                    <Button
                        android:id="@+id/btnReset"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="@string/btn_reset"
                        android:backgroundTint="@color/gray_button"
                        android:textColor="@color/black" />

                    <Button
                        android:id="@+id/btnSubmit"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="@string/btn_submit"
                        android:backgroundTint="@color/primary"
                        android:textColor="@color/white" />
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
