<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/drawerLayout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 主畫面：原本的 ConstraintLayout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/rootConstraintLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/gray">

        <!-- 固定頂部 Fragment -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/topNavFragment"
            android:name="com.yuchens.equipinspectandroid.ui.fragment.TopNavFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintTop_toTopOf="parent"
            tools:layout="@layout/fragment_top_nav" />

        <!-- 中間內容切換區 -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/containerFragment"
            android:layout_width="0dp"
            android:layout_height="0dp"
            app:layout_constraintTop_toBottomOf="@id/topNavFragment"
            app:layout_constraintBottom_toTopOf="@id/bottomNavFragment"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <!-- 固定底部 Fragment -->
        <androidx.fragment.app.FragmentContainerView
            android:id="@+id/bottomNavFragment"
            android:name="com.yuchens.equipinspectandroid.ui.fragment.BottomNavFragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="parent"
            tools:layout="@layout/fragment_bottom_nav" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- 左側滑出的選單 -->
    <com.google.android.material.navigation.NavigationView
        android:id="@+id/navigationView"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_gravity="start"
        app:menu="@menu/drawer_menu"
        app:headerLayout="@layout/layout_menu_header"
        android:background="#333"
        app:itemTextColor="@color/white"
        app:itemIconTint="@color/white"
        app:itemTextAppearance="@style/NavigationViewTextAppearance"
        app:itemIconSize="32dp"
        app:itemIconPadding="12dp"
        app:itemHorizontalPadding="20dp"
        app:itemVerticalPadding="12dp" />

</androidx.drawerlayout.widget.DrawerLayout>
